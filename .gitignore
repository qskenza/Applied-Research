# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Quantum ML for Physiological Stress Classification (WESAD)
# ─────────────────────────────────────────────────────────────────────────────


# ── WESAD data — never commit raw data ───────────────────────────────────────
data/
WESAD/
*.pkl
*.pickle


# ── Processed / intermediate data ────────────────────────────────────────────
processed/
features/
windows/
*.npy
*.npz
*.h5
*.hdf5
*.csv          # generated feature files; keep manually added reference CSVs
!references/*.csv


# ── Model artifacts & checkpoints ────────────────────────────────────────────
models/
checkpoints/
*.joblib
*.pt
*.pth
*.ckpt


# ── Results (large or auto-generated) ────────────────────────────────────────
results/raw/
logs/


# ── Jupyter notebook artifacts ────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
# Strip notebook output before committing (keep code, remove cell output)
# Use: jupyter nbconvert --clear-output --inplace notebooks/*.ipynb


# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python


# ── Virtual environments ──────────────────────────────────────────────────────
venv/
env/
.venv/
.env/
ENV/


# ── Distribution / packaging ──────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg
.eggs/


# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini


# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~


# ── Environment variables / secrets ──────────────────────────────────────────
.env
.env.local
*.secret


# ── Qiskit cache & runtime artifacts ─────────────────────────────────────────
qiskit_cache/
ibmq_credentials.json